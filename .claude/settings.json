{
  "permissions": {
    "allow": [
      "Bash(make:*)",
      "Bash(pytest:*)",
      "Bash(python:*)",
      "Bash(docker:*)",
      "Bash(git:*)",
      "Bash(pip:*)",
      "Bash(uvicorn:*)"
    ]
  },
  "autoMemory": true,
  "autoMemoryDirectory": ".claude/memory",
  "hooks": {
    "PreCompact": [
      {
        "type": "command",
        "command": "python .claude/hooks/pre_compact.py"
      }
    ],
    "Stop": [
      {
        "type": "command",
        "command": "python .claude/hooks/on_stop.py"
      }
    ]
  }
}
